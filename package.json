{
  "name": "agenthub-multiagentcowork",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf .turbo node_modules",
    "db:generate": "drizzle-kit generate --config db/drizzle.config.ts",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seeds/index.ts",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "vitest run tests/e2e",
    "test:integration": "vitest run tests/integration",
    "test:load": "node tests/load/placeholder.js",
    "test:unit": "turbo run test"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.39.3",
    "eslint": "^9.14.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.4",
    "zod": "^3.24.1"
  }
}
